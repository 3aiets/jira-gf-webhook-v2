# Shared secret expected in the X-Webhook-Secret request header.
# Set the same value in your Jira Automation "Send web request" headers.
WEBHOOK_SECRET=replace-me-with-a-long-random-string

# Optional: project key allow-list (comma-separated). Leave empty to allow all.
ALLOWED_PROJECT_KEYS=GF

# Directory where received events are persisted as JSON.
EVENTS_DIR=./events

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Server bind config (used by Uvicorn when running locally).
HOST=0.0.0.0
PORT=8000
