# Inbound auth mode for /webhooks/jira:
#   "jwt"           — modern OAuth 2.0 platform webhook (verifies a bearer JWT
#                     signed with the OAuth app's client_secret).
#   "shared_secret" — legacy Jira Automation rule (verifies X-Webhook-Secret).
AUTH_MODE=jwt

# --- Legacy mode (only required when AUTH_MODE=shared_secret) ---
# Shared secret expected in the X-Webhook-Secret request header.
# Set the same value in your Jira Automation "Send web request" headers.
WEBHOOK_SECRET=replace-me-with-a-long-random-string

# --- Atlassian OAuth 2.0 (3LO) — required when AUTH_MODE=jwt ---
# Create an app at https://developer.atlassian.com/console/myapps/
# (Permissions: read:jira-work, manage:jira-webhook). Cloud ID is discovered
# automatically by `python -m app.admin.register_webhook oauth-init`.
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_CLOUD_ID=
JIRA_BASE_URL=https://your-domain.atlassian.net
OAUTH_REDIRECT_URI=http://localhost:8765/callback
OAUTH_TOKEN_FILE=./.oauth_tokens.json
# Public URL where Atlassian can reach this receiver (e.g. an ngrok URL).
PUBLIC_RECEIVER_URL=

# Optional: project key allow-list (comma-separated). Leave empty to allow all.
ALLOWED_PROJECT_KEYS=GF

# Directory where received events are persisted as JSON.
EVENTS_DIR=./events

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Server bind config (used by Uvicorn when running locally).
HOST=0.0.0.0
PORT=8000
